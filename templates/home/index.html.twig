                            <td>Consultation generaliste</td>
                            <td class="ameli-amount">18,50 &euro;</td>
                            <td><span class="ameli-badge ameli-badge-paid">Rembourse</span></td>
                        </tr>
                        <tr>
                            <td>12/03/2026</td>
