{% extends 'base.html.twig' %}

{% block title %}Mon compte ameli{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
    --ameli-blue: #1746A2;
    --ameli-blue-dark: #0F3280;
    --ameli-blue-light: #4A7BD5;
    --ameli-green: #00853E;
    --ameli-green-light: #e6f5ed;
    --ameli-bg: #F5F6FA;
    --ameli-white: #FFFFFF;
    --ameli-text: #333333;
    --ameli-text-light: #666666;
    --ameli-text-muted: #999999;
    --ameli-border: #E0E0E0;
    --ameli-footer-bg: #31415a;
    --ameli-footer-text: #FFFFFF;
    --ameli-orange: #E8943A;
    --ameli-red: #D64541;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
    height: 100%;
    font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--ameli-bg);
    color: var(--ameli-text);
    font-size: 14px;
    line-height: 1.5;
}

.ameli-page {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

/* ═══════════════ NAVBAR ═══════════════ */
.ameli-navbar {
    background: var(--ameli-white);
    border-bottom: 3px solid var(--ameli-blue);
    padding: 12px 40px;
    display: flex;
    align-items: center;
    gap: 16px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}

.ameli-navbar-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
}

.ameli-navbar-logo img {
    height: 52px;
    width: auto;
    object-fit: contain;
}

.ameli-navbar-divider {
    width: 1px;
    height: 36px;
    background: var(--ameli-border);
    margin: 0 12px;
}

.ameli-navbar-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--ameli-blue);
    flex: 1;
}

.ameli-navbar-title span { color: var(--ameli-green); }

.ameli-navbar-user {
    display: flex;
    align-items: center;
    gap: 12px;
}

.ameli-navbar-email {
    font-size: 0.85rem;
    color: var(--ameli-text-light);
    font-weight: 500;
}

.ameli-navbar-logout {
    background: none;
    border: 1px solid var(--ameli-border);
    border-radius: 4px;
    color: var(--ameli-text-light);
    padding: 6px 16px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
    font-family: inherit;
}

.ameli-navbar-logout:hover {
    border-color: var(--ameli-red);
    color: var(--ameli-red);
    background: #fff5f5;
}

/* ═══════════════ WELCOME BANNER ═══════════════ */
.ameli-welcome {
    background: linear-gradient(135deg, var(--ameli-blue) 0%, var(--ameli-blue-light) 100%);
    padding: 32px 40px;
    color: #ffffff;
}

.ameli-welcome-inner {
    max-width: 1100px;
    margin: 0 auto;
}

.ameli-welcome h1 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 4px;
}

.ameli-welcome p {
    font-size: 0.9rem;
    opacity: 0.85;
}

/* ═══════════════ MAIN CONTENT ═══════════════ */
.ameli-main {
    flex: 1;
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    padding: 30px 40px 50px;
}

/* ═══════════════ QUICK ACCESS GRID ═══════════════ */
.ameli-section-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--ameli-text);
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--ameli-blue);
    display: inline-block;
}

.ameli-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
}

.ameli-card {
    background: var(--ameli-white);
    border-radius: 8px;
    padding: 24px 20px;
    text-align: center;
    text-decoration: none;
    color: var(--ameli-text);
    border: 1px solid var(--ameli-border);
    transition: all 0.2s;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
}

.ameli-card:hover {
    border-color: var(--ameli-blue);
    box-shadow: 0 4px 16px rgba(23,70,162,0.12);
    transform: translateY(-2px);
}

.ameli-card-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.ameli-card-icon svg,
.ameli-card-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.ameli-card-icon-blue { background: #e8f0fe; }
.ameli-card-icon-blue svg { stroke: var(--ameli-blue); }

.ameli-card-icon-green { background: var(--ameli-green-light); }
.ameli-card-icon-green svg { stroke: var(--ameli-green); }

.ameli-card-icon-orange { background: #fef3e0; }
.ameli-card-icon-orange svg { stroke: var(--ameli-orange); }

.ameli-card-icon-red { background: #fde8e8; }
.ameli-card-icon-red svg { stroke: var(--ameli-red); }

.ameli-card-label {
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.3;
}

.ameli-card-desc {
    font-size: 0.78rem;
    color: var(--ameli-text-muted);
    line-height: 1.3;
}

/* ═══════════════ TWO COLUMNS LAYOUT ═══════════════ */
.ameli-two-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 40px;
}

/* ═══════════════ PAYMENTS TABLE ═══════════════ */
.ameli-panel {
    background: var(--ameli-white);
    border-radius: 8px;
    border: 1px solid var(--ameli-border);
    padding: 24px;
}

.ameli-panel-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ameli-blue);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.ameli-panel-title svg {
    width: 20px;
    height: 20px;
    stroke: var(--ameli-blue);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
}

.ameli-table {
    width: 100%;
    border-collapse: collapse;
}

.ameli-table th {
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ameli-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 8px 0;
    border-bottom: 1px solid var(--ameli-border);
}

.ameli-table td {
    padding: 12px 0;
    font-size: 0.85rem;
    border-bottom: 1px solid #f0f0f0;
}

.ameli-table tr:last-child td {
    border-bottom: none;
}

.ameli-amount {
    font-weight: 600;
    color: var(--ameli-green);
}

.ameli-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 0.72rem;
    font-weight: 600;
}

.ameli-badge-paid {
    background: var(--ameli-green-light);
    color: var(--ameli-green);
}

.ameli-badge-pending {
    background: #fef3e0;
    color: #b87a00;
}

/* ═══════════════ INFO CARDS ═══════════════ */
.ameli-info-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid #f0f0f0;
}

.ameli-info-item:last-child {
    border-bottom: none;
}

.ameli-info-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #e8f0fe;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.ameli-info-icon svg {
    width: 18px;
    height: 18px;
    stroke: var(--ameli-blue);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
}

.ameli-info-text h4 {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ameli-text);
    margin-bottom: 2px;
}

.ameli-info-text p {
    font-size: 0.8rem;
    color: var(--ameli-text-muted);
    line-height: 1.4;
}

.ameli-link {
    color: var(--ameli-blue);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 16px;
    transition: text-decoration 0.2s;
}

.ameli-link:hover {
    text-decoration: underline;
}

/* ═══════════════ NOTIFICATION BANNER ═══════════════ */
.ameli-notif {
    background: #e8f0fe;
    border-left: 4px solid var(--ameli-blue);
    border-radius: 0 8px 8px 0;
    padding: 16px 20px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
}

.ameli-notif svg {
    width: 22px;
    height: 22px;
    stroke: var(--ameli-blue);
    fill: none;
    stroke-width: 1.5;
    flex-shrink: 0;
}

.ameli-notif-text {
    font-size: 0.88rem;
    color: var(--ameli-text);
    flex: 1;
}

.ameli-notif-text strong {
    font-weight: 600;
}

/* ═══════════════ FOOTER ═══════════════ */
.ameli-footer {
    background: var(--ameli-footer-bg);
    padding: 20px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
}

.ameli-footer-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
}

.ameli-footer-logo img {
    height: 50px;
    width: auto;
    object-fit: contain;
    image-rendering: -webkit-optimize-contrast; /* Imrove sharpness */
}

.ameli-footer-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    flex: 1;
    justify-content: flex-end; /* Align links to the right of the logo */
    padding-left: 40px;
}

.ameli-footer-links a {
    color: var(--ameli-footer-text);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0 16px;
    opacity: 1;
    white-space: nowrap;
    transition: opacity 0.2s;
}

.ameli-footer-links a:hover {
    text-decoration: underline;
}

.ameli-footer-separator {
    color: rgba(255,255,255,0.4);
    font-size: 0.9rem;
    font-weight: 400;
}

/* ameli-footer-site class is no longer used separately */

/* ═══════════════ RESPONSIVE ═══════════════ */
@media (max-width: 900px) {
    .ameli-two-cols {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 768px) {
    .ameli-navbar {
        padding: 10px 16px;
    }
    .ameli-navbar-logo img { height: 40px; }
    .ameli-navbar-email { display: none; }
    .ameli-welcome { padding: 24px 16px; }
    .ameli-welcome h1 { font-size: 1.2rem; }
    .ameli-main { padding: 20px 16px 40px; }
    .ameli-cards-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }
    .ameli-footer {
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 20px 16px;
    }
    .ameli-footer-links a {
        padding: 4px 10px;
        font-size: 0.72rem;
    }
}

@media (max-width: 480px) {
    .ameli-navbar-divider,
    .ameli-navbar-title { display: none; }
    .ameli-cards-grid {
        grid-template-columns: 1fr 1fr;
    }
    .ameli-card { padding: 16px 12px; }
    .ameli-footer-links a { border-right: none; padding: 4px 8px; }
}
</style>
{% endblock %}

{% block body %}
<div class="ameli-page">

    <!-- ═══════════════ NAVBAR ═══════════════ -->
    <nav class="ameli-navbar">
        <a href="{{ path('app_home') }}" class="ameli-navbar-logo">
            <img src="{{ asset('images/ameli_assurance_logo.png') }}" alt="l'Assurance Maladie">
        </a>
        <div class="ameli-navbar-divider"></div>
        <div class="ameli-navbar-title">Compte <span>ameli</span></div>
        <div class="ameli-navbar-user">
            <span class="ameli-navbar-email">{{ email }}</span>
            <a href="{{ path('app_logout') }}" class="ameli-navbar-logout">Se deconnecter</a>
        </div>
    </nav>

    <!-- ═══════════════ WELCOME BANNER ═══════════════ -->
    <section class="ameli-welcome">
        <div class="ameli-welcome-inner">
            <h1>Bonjour !</h1>
            <p>Bienvenue sur votre espace personnel ameli.</p>
