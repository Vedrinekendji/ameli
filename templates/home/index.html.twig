                            <td class="ameli-amount">7,20 &euro;</td>
                            <td><span class="ameli-badge ameli-badge-paid">Rembourse</span></td>
                        </tr>
                        <tr>
                            <td>05/03/2026</td>
                            <td>Analyses medicales</td>
                            <td class="ameli-amount">42,00 &euro;</td>
                            <td><span class="ameli-badge ameli-badge-pending">En cours</span></td>
                        </tr>
                        <tr>
                            <td>28/02/2026</td>
                            <td>Consultation specialiste</td>
                            <td class="ameli-amount">35,00 &euro;</td>
                            <td><span class="ameli-badge ameli-badge-paid">Rembourse</span></td>
                        </tr>
                    </tbody>
                </table>
                <a href="#" class="ameli-link">
