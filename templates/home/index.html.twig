        <div class="ameli-cards-grid">

            <a href="#" class="ameli-card">
                <div class="ameli-card-icon">
                    <img src="{{ asset('images/paiement_icon.png') }}" alt="Mes paiements">
                </div>
                <span class="ameli-card-label">Mes paiements</span>
                <span class="ameli-card-desc">Suivre mes remboursements</span>
            </a>

            <a href="#" class="ameli-card">
                <div class="ameli-card-icon">
                    <img src="{{ asset('images/attestation_icon.png') }}" alt="Mes attestations">
                </div>
                <span class="ameli-card-label">Mes attestations</span>
                <span class="ameli-card-desc">Telecharger mes documents</span>
            </a>

            <a href="#" class="ameli-card">
                <div class="ameli-card-icon">
                    <img src="{{ asset('images/vitale_icon.png') }}" alt="Ma carte Vitale">
                </div>
                <span class="ameli-card-label">Ma carte Vitale</span>
                <span class="ameli-card-desc">Informations et mise a jour</span>
            </a>

            <a href="#" class="ameli-card">
                <div class="ameli-card-icon">
                    <img src="{{ asset('images/ceam_icon.png') }}" alt="Carte europeenne">
                </div>
                <span class="ameli-card-label">Carte europeenne</span>
                <span class="ameli-card-desc">Commander ma CEAM</span>
            </a>

            <a href="#" class="ameli-card">
                <div class="ameli-card-icon ameli-card-icon-blue">
                    <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <span class="ameli-card-label">Mes messages</span>
                <span class="ameli-card-desc">Contacter l'Assurance Maladie</span>
            </a>

            <a href="#" class="ameli-card">
                <div class="ameli-card-icon">
                    <img src="{{ asset('images/situation_icon.png') }}" alt="Changement de situation">
                </div>
                <span class="ameli-card-label">Changement de situation</span>
                <span class="ameli-card-desc">Demenagement, emploi...</span>
            </a>

        </div>

        <!-- Two columns -->
        <div class="ameli-two-cols">

            <!-- Derniers remboursements -->
            <div class="ameli-panel">
                <div class="ameli-panel-title">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
