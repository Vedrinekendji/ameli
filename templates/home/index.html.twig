                <a href="#" class="ameli-link">
                    Voir mon profil complet &rarr;
                </a>
            </div>

        </div>

    </main>

    <!-- ═══════════════ FOOTER ═══════════════ -->
    <footer class="ameli-footer">
        <div class="ameli-footer-logo">
            <img src="{{ asset('images/ameli_footer_logo.png') }}" alt="l'Assurance Maladie">
        </div>
        <div class="ameli-footer-links">
            <a href="#">Mentions légales et CGU</a>
            <span class="ameli-footer-separator">|</span>
            <a href="#">Aide et Accessibilité : non conforme</a>
            <span class="ameli-footer-separator">|</span>
            <a href="#">Recommandations de sécurité</a>
            <span class="ameli-footer-separator">|</span>
            <a href="#">Protection des données personnelles</a>
            <span class="ameli-footer-separator">|</span>
            <a href="{{ path('app_welcome') }}">Site Ameli</a>
        </div>
    </footer>

</div>
{% endblock %}
